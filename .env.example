# Copy this file to .env and fill in real values. Never commit .env.

# Django
SECRET_KEY=your-secret-key-here
DJANGO_ENV=local
API_PULL_TOKEN=your-api-pull-token-here

# Database
POSTGRE_PASS=your-postgres-password-here

# Email
MAIL=you@example.com
MAIL_PASS=your-email-password-here

# Sports data
SPORTSDB_API_KEY=your-sportsdb-api-key-here

# AI provider (supported: gemini)
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here
